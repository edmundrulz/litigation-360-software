.client-module {
  width: 100%;
  max-width: none;
  box-sizing: border-box;
}

.client-module-header {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 16px;
}

.client-status {
  padding: 10px 12px;
  border: 1px solid #d7dce5;
  border-radius: 8px;
  background: #f7f9fc;
